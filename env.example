# SkolarPay — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local dev
# Add ALL to Vercel → Settings → Environment Variables for production

# ── REQUIRED ────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/skolarpay?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/skolarpay"
JWT_SECRET="run: openssl rand -base64 32"

# ── PAYMENT APIs (add when partnership approved) ─────────────
# 1LINK IBFT: https://1link.net.pk
ONELINK_API_URL=""
ONELINK_INSTITUTION_ID=""
ONELINK_API_KEY=""

# Easypaisa: https://easypaisa.com.pk/business
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""

# JazzCash: https://sandbox.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
